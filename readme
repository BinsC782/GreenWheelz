  <script>
    // Brand filter
    document.querySelectorAll('.brand-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.brand-btn').forEach(b => b.classList.remove('active-brand'));
        btn.classList.add('active-brand');
      });
    });

    // Info card update on car hover
    document.querySelectorAll('.car').forEach(car => {
      car.addEventListener('mouseenter', () => {
        const name = car.dataset.name;
        if (!name) return;
        document.getElementById('infoTitle').textContent = name;
        document.getElementById('infoRange').textContent = car.dataset.range;
        document.getElementById('infoSpeed').textContent = car.dataset.speed;
        document.getElementById('infoCharge').textContent = car.dataset.charge;
      });
    });

    // Compare logic
    let compareQueue = [];

    document.querySelectorAll('.compare-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const car = btn.closest('.car');
        const data = {
          name: car.dataset.name,
          range: car.dataset.range,
          speed: car.dataset.speed,
          charge: car.dataset.charge,
        };

        const idx = compareQueue.findIndex(c => c.name === data.name);
        if (idx !== -1) {
          compareQueue.splice(idx, 1);
          btn.textContent = 'Compare';
          btn.style.background = '';
          return;
        }

        if (compareQueue.length >= 2) {
          // Replace oldest
          const oldName = compareQueue[0].name;
          document.querySelectorAll('.car').forEach(c => {
            if (c.dataset.name === oldName) {
              const b = c.querySelector('.compare-btn');
              b.textContent = 'Compare';
              b.style.background = '';
            }
          });
          compareQueue.shift();
        }

        compareQueue.push(data);
        btn.textContent = '✓ Selected';

        if (compareQueue.length === 2) {
          openModal();
        }
      });
    });

    function openModal() {
      const [c1, c2] = compareQueue;
      document.getElementById('car1Label').textContent = c1.name;
      document.getElementById('car2Label').textContent = c2.name;
      document.getElementById('compareCar1').textContent = c1.name;
      document.getElementById('compareCar2').textContent = c2.name;

      // Range — higher is better
      const r1 = parseInt(c1.range); const r2 = parseInt(c2.range);
      document.getElementById('range1').textContent = c1.range;
      document.getElementById('range2').textContent = c2.range;
      document.getElementById('range1').className = r1 >= r2 ? 'winner' : '';
      document.getElementById('range2').className = r2 >= r1 ? 'winner' : '';

      // Speed — lower is better
      const s1 = parseFloat(c1.speed); const s2 = parseFloat(c2.speed);
      document.getElementById('speed1').textContent = c1.speed;
      document.getElementById('speed2').textContent = c2.speed;
      document.getElementById('speed1').className = s1 <= s2 ? 'winner' : '';
      document.getElementById('speed2').className = s2 <= s1 ? 'winner' : '';

      // Charge — lower is better
      const ch1 = parseInt(c1.charge); const ch2 = parseInt(c2.charge);
      document.getElementById('charge1').textContent = c1.charge;
      document.getElementById('charge2').textContent = c2.charge;
      document.getElementById('charge1').className = ch1 <= ch2 ? 'winner' : '';
      document.getElementById('charge2').className = ch2 <= ch1 ? 'winner' : '';

      document.getElementById('compareModal').classList.add('open');
    }

    document.getElementById('closeCompare').addEventListener('click', () => {
      document.getElementById('compareModal').classList.remove('open');
      compareQueue = [];
      document.querySelectorAll('.compare-btn').forEach(b => {
        b.textContent = 'Compare';
        b.style.background = '';
      });
      document.querySelectorAll('.center-car .compare-btn').forEach(b => {
        b.style.background = '';
      });
    });

    document.getElementById('compareModal').addEventListener('click', (e) => {
      if (e.target === document.getElementById('compareModal')) {
        document.getElementById('closeCompare').click();
      }
    });
  </script>
</body>
